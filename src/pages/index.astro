---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="OpenKeyboard">
  <Header />

  <main>
    <section class="hero">
      <h1>OpenKeyboard</h1>
      <p class="tagline">Open source keyboard tools, designs and firmware.</p>
      <div class="actions">
        <a
          href="https://github.com/openkeyboard-org"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
        </a>
      </div>
    </section>

    <section class="features">
      <div class="feature-card">
        <div class="feature-icon">🔧</div>
        <h2>Open Source</h2>
        <p>100% open source and freely available.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌍</div>
        <h2>Community First</h2>
        <p>Built by keyboard enthusiasts, for keyboard enthusiasts.</p>
      </div>
    </section>

    <section id="projects" class="projects">
      <h2 class="section-title">Projects</h2>
      <a href="/opendongle" class="project-card">
        <div class="project-icon">📡</div>
        <div class="project-body">
          <h3>OpenDongle</h3>
          <p>
            A compact, open-source USB Type-A 2.4 GHz wireless receiver, small enough to fit
            inside a standard nano-receiver shell. Built on WCH RISC-V wireless MCUs, with
            two ready-to-fabricate hardware variants.
          </p>
          <div class="project-tags">
            <span class="tag">2.4 GHz receiver</span>
            <span class="tag">KiCad hardware</span>
            <span class="tag">RISC-V firmware</span>
          </div>
          <span class="project-link">Learn more &rarr;</span>
        </div>
      </a>
    </section>
  </main>

  <footer>
    <p>
      &copy; {new Date().getFullYear()} OpenKeyboard contributors
    </p>
  </footer>
</Layout>

<style>
  main {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    text-align: center;
    padding: 6rem 0 4rem;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1rem;
    transition: opacity 0.2s;
  }

  .btn:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
    padding: 4rem 0;
  }

  .feature-card {
    background: var(--color-bg-secondary);
    border-radius: 0.75rem;
    padding: 2rem;
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .feature-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .projects {
    padding: 2rem 0 4rem;
    /* Offset the sticky 4rem header so #projects lands below it. */
    scroll-margin-top: 5rem;
  }

  .section-title {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .project-card {
    display: flex;
    gap: 1.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid transparent;
    border-radius: 0.75rem;
    padding: 2rem;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }

  .project-card:hover {
    text-decoration: none;
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .project-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .project-body h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .project-body p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-hover);
    background: rgba(56, 189, 248, 0.12);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .project-link {
    font-weight: 600;
    color: var(--color-accent);
  }

  footer {
    text-align: center;
    padding: 3rem 2rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-bg-secondary);
    margin-top: 2rem;
  }
</style>
